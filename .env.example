# Copy this file to .env.local and fill in your real Supabase project values.
# Get these from: Supabase Dashboard → Project Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key-here

# Used for sitemap.xml, robots.txt, and Open Graph URLs.
# Set this to your real domain once you have it.
NEXT_PUBLIC_SITE_URL=https://maxgen.com.sa

# Email alerts (Leads, Messages, Applications) sent to support@maxgen.com.sa
# Get a free API key at https://resend.com — verify maxgen.com.sa as a sending
# domain there before setting ALERT_FROM_EMAIL to an @maxgen.com.sa address.
RESEND_API_KEY=
ALERT_FROM_EMAIL=Maxgen Website <onboarding@resend.dev>
